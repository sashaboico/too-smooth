# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Models & artifacts
*.joblib
*.pkl

# Data — keep the folders, ignore the contents (may contain sensitive samples)
data/raw/*
data/processed/*
data/labeled/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/labeled/.gitkeep
# Keep provenance docs tracked, but never the data itself
!data/raw/SOURCE.md

